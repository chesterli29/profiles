# 字体设置
font-family = "Monaco"
font-size = 14

# cursor style
cursor-style = block
cursor-style-blink = true
cursor-opacity = 0.8

#=== 鼠标 ===
mouse-hide-while-typing = true
copy-on-select = clipboard

theme = Atom One Dark

# background
background-opacity = 0.85
background-blur-radius = 30
macos-titlebar-style = transparent
window-padding-x = 10
window-padding-y = 8
window-save-state = always
window-theme = auto
